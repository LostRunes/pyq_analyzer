{
  "topics": [
    {
      "topic_name": "Introduction to Public Health",
      "summary": "Core concepts of public health, its definition, multidisciplinary nature, and key achievements in the 21st century."
    },
    {
      "topic_name": "Core Functions of Public Health",
      "summary": "The three core functions of public health: assessment, policy development, and assurance, and how engineers can contribute to each."
    },
    {
      "topic_name": "Determinants of Health",
      "summary": "Biological, social, environmental, and behavioral factors that influence individual and population health outcomes."
    },
    {
      "topic_name": "Social Determinants of Health",
      "summary": "WHO and CDC models of social determinants including poverty, education, housing, and how they shape disease and health."
    },
    {
      "topic_name": "Epidemiology Fundamentals",
      "summary": "Definition, scope, and history of epidemiology including John Snow's cholera investigation and the germ theory of disease."
    },
    {
      "topic_name": "Epidemiological Triad",
      "summary": "The agent-host-environment model used to explain disease causation and the interplay between these three elements."
    },
    {
      "topic_name": "Measures of Disease Frequency",
      "summary": "Epidemiological measures including incidence, prevalence, and other morbidity indicators used to quantify disease burden."
    },
    {
      "topic_name": "Measures of Association",
      "summary": "Relative risk, odds ratio, and other statistical measures used in epidemiology to quantify the relationship between exposure and disease."
    },
    {
      "topic_name": "Natural History of Disease",
      "summary": "The two phases of disease progression: pre-pathogenesis (before disease onset) and pathogenesis (after disease onset), including incubation and latent periods."
    },
    {
      "topic_name": "Disease Prevention",
      "summary": "Primary, secondary, and tertiary prevention strategies, their definitions, examples, and the role of engineers in each level."
    },
    {
      "topic_name": "Epidemiological Study Designs",
      "summary": "Overview of cross-sectional, case-control, cohort studies, and randomized controlled trials (RCTs), including their strengths and limitations."
    },
    {
      "topic_name": "Epidemiological Surveillance",
      "summary": "Definition and types of surveillance including active and passive surveillance, and their application in public health monitoring."
    },
    {
      "topic_name": "Outbreak Investigation",
      "summary": "Systematic steps taken to investigate and control a disease outbreak in a community."
    },
    {
      "topic_name": "Screening Tests",
      "summary": "Concepts of validity (sensitivity and specificity) and reliability in the context of public health screening programs."
    },
    {
      "topic_name": "Environmental Health",
      "summary": "WHO definition of environmental health, key environmental risk factors, and the impact of pollution and climate change on human health."
    },
    {
      "topic_name": "Environmental Pollution and Health",
      "summary": "Types of environmental pollution (air, water, soil) and their specific effects on human health with examples."
    },
    {
      "topic_name": "Water Pollution and Engineering Solutions",
      "summary": "Health effects of water pollution and how engineering advancements such as treatment technologies can address them."
    },
    {
      "topic_name": "Environmental Sanitation",
      "summary": "Definition, importance of sanitation for public health, and related engineering interventions."
    },
    {
      "topic_name": "International Environmental Conventions",
      "summary": "Key global environmental agreements including the Basel Convention, Rio Earth Summit outcomes, and their objectives."
    },
    {
      "topic_name": "Urbanization and Health",
      "summary": "How rapid urban growth affects population health, including slum living conditions, pollution, and lifestyle changes."
    },
    {
      "topic_name": "Health Promotion",
      "summary": "Definition of health promotion, Ottawa Charter components, and strategies for implementing health promotion in occupational or academic settings."
    },
    {
      "topic_name": "Health Behavior Change Models",
      "summary": "Health Belief Model, Transtheoretical Model, and Theory of Planned Behavior — their constructs, key concepts, and application in public health interventions."
    },
    {
      "topic_name": "Engineering Applications in Public Health",
      "summary": "How engineering disciplines contribute to disease prevention, environmental health, sanitation, and public health system strengthening."
    },
    {
      "topic_name": "Communicable and Non-Communicable Diseases",
      "summary": "Distinction between infectious and chronic diseases, their burden, and the engineer's role in reducing non-communicable disease prevalence."
    },
    {
      "topic_name": "Statistics in Public Health",
      "summary": "Definition and applications of statistics in public health, including data collection, analysis, and interpretation."
    },
    {
      "topic_name": "Variables and Scales of Measurement",
      "summary": "Types of variables (categorical, continuous) and the four scales of measurement: nominal, ordinal, interval, and ratio, with examples."
    },
    {
      "topic_name": "Measures of Central Tendency",
      "summary": "Calculation and interpretation of mean, median, and mode for public health datasets."
    },
    {
      "topic_name": "Health Management Information System (HMIS)",
      "summary": "Definition, applications, strengths, and role of HMIS in managing health data and supporting decision-making in public health."
    },
    {
      "topic_name": "Health Economics",
      "summary": "Concepts of cost-benefit analysis, QALY (Quality-Adjusted Life Year), and economic evaluation methods used in public health priority-setting."
    },
    {
      "topic_name": "Disease and Poverty",
      "summary": "The vicious cycle linking disease burden and poverty, and strategies including engineering interventions to break this cycle."
    }
  ],
